# Default environment for `docker compose` (committed). Copy to `.env` to override locally.
# API connects to compose service names on the internal network.
NODE_ENV=production

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=coros
POSTGRES_PASSWORD=coros_dev_password
POSTGRES_DB=coros_db

REDIS_PASSWORD=redis_secret

JWT_ACCESS_SECRET=change-me-in-production-use-a-long-random-string

# S3-compatible storage (required at API startup). Replace with real credentials for uploads.
STORAGE_ENDPOINT=http://127.0.0.1:9000
STORAGE_BUCKET=coros
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=minio
STORAGE_SECRET_KEY=minio_secret

# Optional: web URL for emails / links
COROS_WEB_URL=http://localhost:4200
